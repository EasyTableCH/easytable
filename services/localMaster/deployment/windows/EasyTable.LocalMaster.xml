<service>
  <id>EasyTable.LocalMaster</id>
  <name>EasyTable LocalMaster</name>
  <description>EasyTable local operational service</description>
  <executable>%BASE%\runtime\node.exe</executable>
  <arguments>%BASE%\service\dist\index.js</arguments>
  <workingdirectory>%BASE%\service</workingdirectory>
  <startmode>Automatic</startmode>
  <onfailure action="restart" delay="10 sec" />
  <logpath>%ProgramData%\EasyTable\LocalMaster\logs</logpath>
  <log mode="roll-by-size"><sizeThreshold>10485760</sizeThreshold><keepFiles>10</keepFiles></log>
  <env name="LOCAL_MASTER_STAFF_DIST" value="%BASE%\staff" />
</service>
